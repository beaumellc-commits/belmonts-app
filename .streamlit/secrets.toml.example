# ─────────────────────────────────────────────────────────────────────────────
# Template des secrets Streamlit
#
# • EN LOCAL (pour tester l'app sur ton Mac) :
#     cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   puis remplis les valeurs ci-dessous.
#
# • EN PROD (sur Streamlit Cloud) :
#   copie-colle TOUT le contenu rempli dans
#   Streamlit Cloud → Settings → Secrets.
#
# /!\ Ne JAMAIS commiter `.streamlit/secrets.toml` (déjà dans .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — onglet "Project Settings → API"
SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_KEY = "eyJ...service_role_key..."  # PRENDRE la clé "service_role"

# Identifiants des utilisateurs de l'app (modifie-les avant la prod !)
[auth]
admin       = "belmonts1978"
commercial1 = "belmonts2024"
commercial2 = "belmonts2024"
